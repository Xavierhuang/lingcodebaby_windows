{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main", "win-*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:event:default",
    "opener:default",
    "opener:allow-open-url",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
