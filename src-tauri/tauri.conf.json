{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LingCodeBaby",
  "version": "1.0.0",
  "identifier": "com.lingcodebaby.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "LingCodeBaby",
        "width": 1040,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0M0M2QUE0REVEMkRBQjAKUldTdzJ0TGVwR284aEl0czZ2VkRpaTNpMWljZmVHY2F5VDdEa2t4WWs0TzRCR2QrZzZOcmU4UUQK",
      "endpoints": [
        "https://lingcode.dev/lingcodebaby/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
